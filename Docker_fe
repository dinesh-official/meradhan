FROM node:20-alpine

RUN apk add RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    build-essential \
    libcairo2-dev \
    libpango1.0-dev \
    libjpeg-dev \
    libgif-dev \
    librsvg2-dev \
    && rm -rf /var/lib/apt/lists/*


COPY . /app

COPY .env /app/packages/
WORKDIR /app/packages/apiGateway
RUN npm install
WORKDIR /app/packages/config
RUN npm install
WORKDIR /app/packages/kyc-providers
RUN npm install
WORKDIR /app/packages/schema
RUN npm install
COPY .env /app/frontend/meradhan/
WORKDIR /app/frontend/meradhan
RUN npm install &&  npm run build 
EXPOSE 4002
CMD ["npm","run","start"]
