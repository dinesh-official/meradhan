FROM node:20-alpine

# Install system dependencies (Alpine)
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    cairo-dev \
    pango-dev \
    jpeg-dev \
    giflib-dev \
    librsvg-dev

# Set working directory
WORKDIR /app

# Copy package files (for caching)
COPY package*.json ./

# Install root dependencies
RUN npm install

# Copy full project
COPY . .

# Copy env file (make sure .env exists in root)
COPY .env /app/frontend/meradhan/.env

# Install dependencies for all packages
WORKDIR /app/packages/apiGateway
RUN npm install

WORKDIR /app/packages/config
RUN npm install

WORKDIR /app/packages/kyc-providers
RUN npm install

WORKDIR /app/packages/schema
RUN npm install

# Build frontend
WORKDIR /app/frontend/meradhan
RUN npm install && npm run build

# Expose port
EXPOSE 4002

# Start app
CMD ["npm","run","start"]
