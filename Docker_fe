FROM node:20-alpine

RUN apk add --no-cache
python3
make
g++
cairo-dev
pango-dev
jpeg-dev
giflib-dev
librsvg-dev

WORKDIR /app

COPY . .

COPY .env /app/packages/

WORKDIR /app/packages/apiGateway
RUN npm install

WORKDIR /app/packages/config
RUN npm install

WORKDIR /app/packages/kyc-providers
RUN npm install

WORKDIR /app/packages/schema
RUN npm install

COPY .env /app/frontend/meradhan/

WORKDIR /app/frontend/meradhan
RUN npm install && npm run build

EXPOSE 4002

CMD ["npm","run","start"]
