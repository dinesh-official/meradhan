model NseDataSet {
    id Int @id @default(autoincrement())

    // One-to-one relationship with CustomerProfileDataModel
    customerProfileDataModelId Int                      @unique
    customerProfileDataModel   CustomerProfileDataModel @relation(fields: [customerProfileDataModelId], references: [id], onDelete: Cascade)

    participant                 NseCbricsParticipantModel @relation(fields: [nseCbricsParticipantModelId], references: [id])
    nseCbricsParticipantModelId Int

    @@map("nse_customer_data_set")
}

model NseCbricsParticipantModel {
    key Int @id @default(autoincrement())

    id             Int       @unique
    loginId        String    @unique
    userId         Int       @unique
    actualStatus   Int
    workflowStatus Int
    firstName      String
    panNo          String
    custodian      String?
    contactPerson  String
    mobileList     String[]
    emailList      String[]
    telephone      String
    fax            String?
    address        String?
    address2       String?
    address3       String?
    stateCode      String
    regAddress     String
    leiCode        String?
    expiryDate     DateTime?
    panVerStatus   Int?
    panVerRemarks  String?
    remarks        String?
    dobDoi         String?

    bankAccountList NSEBankAccount[]
    dpAccountList   NSEDpAccount[]

    /// Timestamps
    createdAt  DateTime     @default(now())
    updatedAt  DateTime     @updatedAt
    NSEDATASET NseDataSet[]

    @@map("nse_cbrics_unregistered_participant")
}

model NSEBankAccount {
    id Int @id @default(autoincrement())

    bankName       String
    bankIFSC       String
    bankAccountNo  String
    isDefault      DefaultSelect
    workflowStatus Int?
    status         String?

    createdAt                   DateTime                   @default(now())
    updatedAt                   DateTime                   @updatedAt
    NSECbricsParticipantModel   NseCbricsParticipantModel? @relation(fields: [nseCbricsParticipantModelId], references: [id])
    nseCbricsParticipantModelId Int?

    @@map("nse_cbrics_bank_account")
}

model NSEDpAccount {
    id Int @id @default(autoincrement())

    dpType         DepositoryName
    dpId           String?
    benId          String
    isDefault      DefaultSelect
    workflowStatus Int?
    status         String?

    createdAt                   DateTime                   @default(now())
    updatedAt                   DateTime                   @updatedAt
    NSECbricsParticipantModel   NseCbricsParticipantModel? @relation(fields: [nseCbricsParticipantModelId], references: [id])
    nseCbricsParticipantModelId Int?

    @@map("nse_cbrics_dp_account")
}

enum DefaultSelect {
    Y
    N
}

model NseIsinSecurityReceipt {
    id            Int      @id @default(autoincrement())
    symbol        String   @unique
    couponRate    Float
    issueCategory String
    listed        String
    maturityDate  DateTime
    faceValue     Float
    description   String
    type          String
    issuer        String

    @@map("nse_isin_security_receipts")
}

model SettleOrderModel {
    id                     Int           @unique
    orderNumber            String        @db.VarChar(30)
    symbol                 String        @db.VarChar(30)
    buyParticipantLoginId  String        @db.VarChar(30)
    sellParticipantLoginId String        @db.VarChar(30)
    price                  Decimal       @db.Decimal(15, 4)
    yieldType              YieldTypeSort
    yield                  Decimal       @db.Decimal(15, 4)
    value                  Decimal       @db.Decimal(17, 2)
    buyerRefNo             String?       @db.VarChar(50)
    sellerRefNo            String?       @db.VarChar(50)
    buyBackofficeLoginId   String?       @db.VarChar(30)
    sellBackofficeLoginId  String?       @db.VarChar(30)
    buyBrokerLoginId       String?       @db.VarChar(30)
    sellBrokerLoginId      String?       @db.VarChar(30)
    source                 Int

    modSettleDate    String?
    modQuantity      Decimal? @db.Decimal(17, 2)
    modAccrInt       Decimal? @db.Decimal(17, 2)
    modConsideration Decimal?

    settlementNo               String?
    stampDutyAmount            Decimal? @db.Decimal(17, 2)
    stampDutyBearer            String?  @db.VarChar(30)
    buyerFundPayinObligation   Decimal? @db.Decimal(17, 2)
    sellerFundPayoutObligation Decimal? @db.Decimal(17, 2)
    fundPayinRefId             String?  @db.VarChar(50)

    settleStatus Int

    secPayinQuantity Decimal? @db.Decimal(17, 2)
    secPayinRemarks  String?  @db.VarChar(50)
    secPayinTime     String?

    fundsPayinAmount  Decimal? @db.Decimal(17, 2)
    fundsPayinRemarks String?  @db.VarChar(50)
    fundsPayinTime    String?

    payoutRemarks String? @db.VarChar(50)
    payoutTime    String?

    ifscCode  String? @db.VarChar(11)
    accountNo String? @db.VarChar(62)
    utrNumber String? @db.VarChar(16)
    dpId      String? @db.VarChar(8)
    benId     String? @db.VarChar(16)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("settle_order")
}

enum YieldTypeSort {
    P
    C
    M
}

model NseWebhookNotification {
    id        Int      @id @default(autoincrement())
    payload   Json?
    type      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("nse_webhook_notification")
}
