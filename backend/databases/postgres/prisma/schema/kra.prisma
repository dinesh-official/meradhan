model KraFatcaAddlDtls {
    id                          Int     @id @default(autoincrement())
    kraDownloadResponseId       Int
    appFatcaEntityPan           String? @map("app_fatca_entity_pan")
    appFatcaCountryResidency    String? @map("app_fatca_country_residency")
    appFatcaTaxIdentificationNo String? @map("app_fatca_tax_identification_no")
    appFatcaTaxExemptFlag       String? @map("app_fatca_tax_exempt_flag")
    appFatcaTaxExemptReason     String? @map("app_fatca_tax_exempt_reason")

    kraDownloadResponse KraDownloadResponse @relation(fields: [kraDownloadResponseId], references: [id])

    @@map("kra_fatca_addl_dtls")
}

model KraAppSummRec {
    id                       Int     @id @default(autoincrement())
    appReqDate               String? @map("app_req_date")
    appOthkraBatch           String? @map("app_othkra_batch")
    appOthkraCode            String? @map("app_othkra_code")
    appResponseDate          String? @map("app_response_date")
    appTotalRec              Int?    @map("app_total_rec")
    noOfFatcaAddlDtlsRecords Int?    @map("no_of_fatca_addl_dtls_records")

    kraDownloadResponses KraDownloadResponse[]

    @@map("kra_app_summ_rec")
}

