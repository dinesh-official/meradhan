model Storage {
    id         Int               @id @default(autoincrement())
    fileId     String            @unique
    userId     Int
    fileName   String
    mimeType   String
    s3Key      String            @unique
    size       BigInt?
    visibility StorageVisibility @default(PRIVATE)
    status     StorageStatus     @default(ACTIVE)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@index([userId])
    @@map("storage")
}

enum StorageStatus {
    ACTIVE
    DELETED
}

enum StorageVisibility {
    PRIVATE
    PUBLIC
}
