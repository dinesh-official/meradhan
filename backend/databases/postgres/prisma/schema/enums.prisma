/// Defines CRM user roles with varying access levels
enum CrmUserROLE {
  /// Can only view data, no modifications allowed
  VIEWER
  /// Full access to all operations
  ADMIN
  /// Super admin: KYC view, delete customer, create super admin only
  SUPER_ADMIN
  /// Handles lead generation and conversion
  SALES
  /// Manages customer issues and support requests
  SUPPORT
  /// Assigned relationship manager for customers
  RELATIONSHIP_MANAGER
}

/// Defines overall account status for a customer
enum AccountStatus {
  /// Account is active and usable
  ACTIVE
  /// Account is temporarily or permanently suspended
  SUSPENDED
}

