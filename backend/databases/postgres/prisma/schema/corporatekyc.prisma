// ---------------------------------------------------------------------------
// Corporate KYC – entity details, correspondence address, documents, FATCA,
// bank accounts, demat accounts, directors, promoters, authorised signatories
// ---------------------------------------------------------------------------

model CorporateKycModel {
  id Int @id @default(autoincrement())

  /// Link to customer (one-to-one: one corporate KYC per customer)
  customerProfileDataModel   CustomerProfileDataModel @relation(fields: [customerProfileDataModelId], references: [id], onDelete: Cascade)
  customerProfileDataModelId Int                      @unique

  // ---------- Entity details ----------
  entityName                     String
  dateOfCommencementOfBusiness   DateTime?
  countryOfIncorporation         String?
  panCopyFileUrl                 String?  /// PAN copy document (file path or URL)
  entityConstitutionType         EntityConstitutionType?
  otherConstitutionType          String?  /// Required when entityConstitutionType is OTHER
  dateOfIncorporation            DateTime?
  placeOfIncorporation           String?
  panNumber                      String?
  cinOrRegistrationNumber        String?

  // ---------- Correspondence address ----------
  correspondenceFullAddress String?
  correspondenceLine1        String?
  correspondenceLine2        String?
  correspondenceCity         String?
  correspondenceDistrict     String?
  correspondencePinCode     String?
  correspondenceState       String?

  // ---------- Documents (file paths or URLs) ----------
  balanceSheetCopyUrl                 String?
  certificateOfIncorporationUrl       String?
  memorandumCopyUrl                  String?
  boardResolutionCopyUrl             String?
  gstCopyUrl                         String?
  clientMasterHoldingCopyUrl         String?
  annualIncome                       String?  /// Annual income (text/number)
  shareHoldingPatternCopyUrl         String?
  certificateOfCommencementOfBizUrl  String?
  articlesOfAssociationUrl          String?
  gstNumber                         String?
  directorsListCopyUrl              String?
  powerOfAttorneyCopyUrl            String?
  documentsType                     String?

  // ---------- FATCA ----------
  fatcaApplicable                   Boolean  @default(false)
  fatcaEntityName                   String?
  fatcaCountryOfIncorporation       String?
  fatcaEntityType                   CorporateEntityType?
  fatcaClassification               String?
  giin                              String?  /// Global Intermediary Identification Number (if applicable)
  taxResidencyOfEntity               String?
  declarationByAuthorisedSignatory  Boolean  @default(false)

  // ---------- Relations (one-to-many) ----------
  bankAccounts            CorporateKycBankAccountModel[]
  dematAccounts           CorporateKycDematAccountModel[]
  directors               CorporateKycDirectorModel[]
  promoters               CorporateKycPromoterModel[]
  authorisedSignatories    CorporateKycAuthorisedSignatoryModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("corporate_kyc")
}

// ---------------------------------------------------------------------------
// Bank account(s) for Corporate KYC
// ---------------------------------------------------------------------------
model CorporateKycBankAccountModel {
  id Int @id @default(autoincrement())

  corporateKycModel   CorporateKycModel @relation(fields: [corporateKycModelId], references: [id], onDelete: Cascade)
  corporateKycModelId Int

  accountHolderName String
  accountNumber     String
  branch            String?
  bankName          String
  ifscCode          String
  /// Bank proof (statement / cancel cheque) – stored as JSON array of file URLs
  bankProofFileUrls  Json?   @default("[]")
  isPrimaryAccount   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("corporate_kyc_bank_accounts")
}

// ---------------------------------------------------------------------------
// Demat account(s) for Corporate KYC
// ---------------------------------------------------------------------------
model CorporateKycDematAccountModel {
  id Int @id @default(autoincrement())

  corporateKycModel   CorporateKycModel @relation(fields: [corporateKycModelId], references: [id], onDelete: Cascade)
  corporateKycModelId Int

  depository       DepositoryName  /// CDSL or NSDL
  accountType      String?         /// e.g. SOLO, JOINT, CORPORATE
  dpId             String
  clientId         String
  accountHolderName String
  dematProofFileUrl String?        /// CML statement copy (file path or URL)
  isPrimary        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("corporate_kyc_demat_accounts")
}

// ---------------------------------------------------------------------------
// Director(s) for Corporate KYC
// ---------------------------------------------------------------------------
model CorporateKycDirectorModel {
  id Int @id @default(autoincrement())

  corporateKycModel   CorporateKycModel @relation(fields: [corporateKycModelId], references: [id], onDelete: Cascade)
  corporateKycModelId Int

  fullName     String
  pan          String?
  designation  String?
  din          String?   /// Director Identification Number
  email        String?
  mobile       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("corporate_kyc_directors")
}

// ---------------------------------------------------------------------------
// Promoter(s) for Corporate KYC
// ---------------------------------------------------------------------------
model CorporateKycPromoterModel {
  id Int @id @default(autoincrement())

  corporateKycModel   CorporateKycModel @relation(fields: [corporateKycModelId], references: [id], onDelete: Cascade)
  corporateKycModelId Int

  fullName    String
  pan         String?
  designation String?
  din         String?
  email       String?
  mobile      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("corporate_kyc_promoters")
}

// ---------------------------------------------------------------------------
// Authorised signatory(ies) for Corporate KYC
// ---------------------------------------------------------------------------
model CorporateKycAuthorisedSignatoryModel {
  id Int @id @default(autoincrement())

  corporateKycModel   CorporateKycModel @relation(fields: [corporateKycModelId], references: [id], onDelete: Cascade)
  corporateKycModelId Int

  fullName    String
  pan         String
  designation String?
  din         String?
  email       String
  mobile      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("corporate_kyc_authorised_signatories")
}
