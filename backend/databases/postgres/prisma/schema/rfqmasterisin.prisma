model RFQMasterISIN {
    id Int @id @default(autoincrement())

    number          String        @unique
    segment         RFQSegment
    isin            String
    participantCode String
    dealType        DealType
    clientCode      String
    clientRegType   ClientRegType
    buySell         BuySell
    quoteType       QuoteType
    settlementType  Int
    value           Float
    quantity        Int?
    yieldType       YieldType
    yield           Float?
    calcMethod      CalcMethod
    price           Float?
    valueSell       Float?
    quantitySell    Int?
    yieldTypeSell   YieldType?
    yieldSell       Float?
    calcMethodSell  CalcMethod?
    priceSell       Float?
    gtdFlag         YesNo?
    endTime         String?
    quoteNegotiable YesNo?
    valueNegotiable YesNo?
    minFillValue    Float?
    valueStepSize   Float?
    anonymous       YesNo?
    access          Int
    groupList       Int[]
    participantList String[]
    category        String?
    rating          String?
    remarks         String?

    date           String?
    quoteTime      String?
    settlementDate String?
    status         Status  @default(P)
    userLogin      String?
    tradedValue    Float?
    confirmedValue Float?

    createdAt DateTime @default(now())
    createdBy Int?
    updatedBy Int?
    updatedAt DateTime @updatedAt

    @@map("rfq_master_isin")
}

model RFQNegotiation {
    rfqNumber               String
    id                      String                         @unique
    date                    String
    isin                    String?
    buySell                 BuySell?
    initSettlementType      Int?
    initSettlementDate      String?
    initAeCode              String?
    initDealType            DealType?
    initClientCode          String?
    initClientRegType       ClientRegType?
    initValue               Float?
    initQuantity            Int?
    initYieldType           YieldType?
    initYield               Float?
    initCalcMethod          CalcMethod?
    initPrice               Float?
    initAccruedInterest     Float?
    initConsideration       Float?
    initQuoteTime           String?
    initGtdFlag             YesNo?
    initEndTime             String?
    initRemarks             String?
    initLoginId             String?
    respSettlementType      Int?
    respSettlementDate      String?
    respAeCode              String?
    respDealType            DealType?
    respClientCode          String?
    respClientRegType       ClientRegType?
    respValue               Float?
    respQuantity            Int?
    respYieldType           YieldType?
    respYield               Float?
    respCalcMethod          CalcMethod?
    respPrice               Float?
    respAccruedInterest     Float?
    respConsideration       Float?
    respQuoteTime           String?
    respGtdFlag             YesNo?
    respEndTime             String?
    respRemarks             String?
    respLoginId             String?
    status                  NegotiationStatus?
    tradeNumber             String?
    acceptedSettlementType  Int?
    acceptedSettlementDate  String?
    acceptedValue           Float?
    acceptedQuantity        Int?
    acceptedYieldType       YieldType?
    acceptedYield           Float?
    acceptedCalcMethod      CalcMethod?
    acceptedPrice           Float?
    acceptedPutCallDate     String?
    acceptedAccruedInterest Float?
    acceptedConsideration   Float?
    acceptedQuoteTime       String?
    acceptedBySide          BySide?
    acceptedByLoginId       String?
    confirmStatus           NegotiationConfirmationStatus?
    proposedBySide          BySide?
    proposedTime            String?
    confirmedPriceQuoteTime String?
    lastActivityTimestamp   String?
    tradeSplits             Json[]
    createdAt               DateTime                       @default(now())
    createdBy               Int?
    updatedBy               Int?
    updatedAt               DateTime                       @updatedAt

    @@map("rfq_negotiable")
}

enum RFQSegment {
    R
    C
}

enum ClientRegType {
    R
    I
    U
}

enum BuySell {
    B
    S
    X
}

enum QuoteType {
    Y
    B
}

enum YieldType {
    YTM
    YTP
    YTC
}

enum CalcMethod {
    M
    O
}

enum YesNo {
    Y
}

enum Status {
    P
    W
    T
}

enum DealType {
    D
    B
}

enum BySide {
    I
    R
}

enum NegotiationStatus {
    N
    R
    A
    C
    E
    X
}

enum NegotiationConfirmationStatus {
    PP
    PC
    PR
    CA
    CC
    CR
}
