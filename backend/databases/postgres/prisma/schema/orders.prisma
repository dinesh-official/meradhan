model Order {
    id Int @id @default(autoincrement())

    orderNumber String @unique // For user reference (e.g., ORD-123456)

    customerProfileId Int
    customerProfile   CustomerProfileDataModel @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

    // Payment Details (Generic)
    paymentProvider String? // e.g., "RAZORPAY"
    paymentOrderId  String? @unique // Provider's Order ID (e.g., order_123)
    paymentId       String? @unique // Provider's Payment ID (e.g., pay_123)
    paymentMetadata Json? // Store signature, method, vpa, etc. here

    paymentStatus PaymentStatus @default(PENDING)
    status        OrderStatus   @default(PENDING)

    // Financials
    subTotal    Decimal @db.Decimal(15, 2)
    stampDuty   Decimal @db.Decimal(15, 2)
    totalAmount Decimal @db.Decimal(15, 2)

    // Bond Snapshot (Single bond per order)
    isin        String
    bondName    String
    faceValue   Decimal @db.Decimal(15, 2)
    quantity    Int
    unitPrice   Decimal @db.Decimal(15, 2)
    bondDetails Json // Full bond details

    // Relations
    customerBonds CustomerBonds?
    orderLogs     OrderLogs[]

    // General Metadata
    metadata       Json?
    reqOrderNumber String?

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([customerProfileId])
    @@index([paymentOrderId])
    @@index([paymentId])
    @@index([orderNumber])
    @@map("orders")
}

model CustomerBonds {
    id Int @id @default(autoincrement())

    customerProfileId Int
    customerProfile   CustomerProfileDataModel @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

    orderId Int   @unique // One order links to one customer bond
    order   Order @relation(fields: [orderId], references: [id])

    // Snapshot of bond details at purchase (decoupled from Bonds table)
    isin          String
    bondName      String
    faceValue     Decimal  @db.Decimal(15, 2)
    quantity      Int
    purchasePrice Decimal  @db.Decimal(15, 2)
    purchaseDate  DateTime @default(now())

    metadata Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([customerProfileId])
    @@index([isin])
    @@map("customer_bonds")
}

model OrderLogs {
    id Int @id @default(autoincrement())

    orderId Int
    order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

    step   String // e.g. "RFQ_CREATED", "NEGOTIATION_ACCEPTED"
    status String // "SUCCESS", "FAILED", "PENDING"

    // To store specific IDs or results
    outputData Json?

    // To store what happened (errors, full API response for debugging)
    details Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([orderId])
    @@map("order_logs")
}

enum PaymentStatus {
    PENDING
    COMPLETED
    REFUNDED
    CANCELLED
}

enum OrderStatus {
    PENDING
    SETTLED
    APPLIED
    REJECTED
}
