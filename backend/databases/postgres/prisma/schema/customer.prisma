/// Stores authentication and account-related data for customers
model CustomersAuthDataModel {
    id Int @id @default(autoincrement())

    /// Encrypted password (optional if using social login)
    password String?

    /// Type of sign-in used (e.g., EMAIL, GOOGLE, etc.)
    signinWith    SIGNIN_WITH
    socialLoginId String?

    /// Account status (e.g., ACTIVE, INACTIVE, SUSPENDED)
    accountStatus AccountStatus @default(ACTIVE)

    /// Verification Jo
    isPhoneVerified           Boolean   @default(false)
    isEmailVerified           Boolean   @default(false)
    whatsAppNotificationAllow Boolean   @default(false)
    termsAccepted             Boolean   @default(false)
    lastLogin                 DateTime?

    relationshipManager CRMUserDataModel? @relation(fields: [cRMUserDataModelId], references: [id])
    cRMUserDataModelId  Int?

    // One-to-one relation with CustomerProfileDataModel
    customerProfileDataModel CustomerProfileDataModel?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("customers_auth_data")
}

/// Stores customer profile information (public / account details)
model CustomerProfileDataModel {
    id Int @id @default(autoincrement())

    /// Basic identity info
    userName        String  @unique
    firstName       String
    middleName      String
    lastName        String
    gender          Gender?
    legalEntityName String?

    /// Contact details
    emailAddress String  @unique
    phoneNo      String? @unique
    whatsAppNo   String?

    /// Profile visuals and type
    avatar   String?         @default("documents/dummy-avatar.jpg")
    userType UserAccountType @default(INDIVIDUAL)

    /// KYC (Know Your Customer) related info
    kycStatus KYCStatus @default(PENDING)
    kraStatus String    @default("PENDING")

    VerifiedBy    Int?
    verifyDate    DateTime?
    kycSubmitDate DateTime?

    // One-to-one relations
    riskProfile                 CustomersRiskProfileModel? @relation(fields: [customersRiskProfileModelId], references: [id], onDelete: Cascade)
    customersRiskProfileModelId Int?                       @unique

    utility                  CustomersAuthDataModel @relation(fields: [customersAuthDataModelId], references: [id], onDelete: Cascade)
    customersAuthDataModelId Int                    @unique

    aadhaarCard        AADHAARCardModel? @relation(fields: [aADHAARCardModelId], references: [id], onDelete: Cascade)
    aADHAARCardModelId Int?              @unique

    panCard        PanCardModel? @relation(fields: [panCardModelId], references: [id], onDelete: Cascade)
    panCardModelId Int?          @unique

    personalInformation         CustomerPersonalInfoModel? @relation(fields: [customerPersonalInfoModelId], references: [id], onDelete: Cascade)
    customerPersonalInfoModelId Int?                       @unique

    currentAddress        AddressModel? @relation("CurrentAddress", fields: [currentAddressModelId], references: [id], onDelete: Cascade)
    currentAddressModelId Int?          @unique

    permanentAddress        AddressModel? @relation("PermanentAddress", fields: [permanentAddressModelId], references: [id], onDelete: Cascade)
    permanentAddressModelId Int?          @unique

    // Linked accounts
    bankAccounts  CustomersBankAccountModel[]
    dematAccounts CustomersDematAccountModel[]

    /// Corporate KYC (one-to-one; only for corporate customers)
    corporateKyc CorporateKycModel?

    nseDataSet NseDataSet?

    isAFatcaCustomer Boolean @default(false)
    isAPep           Boolean @default(false)
    allowSEBITerms   Boolean @default(false)

    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt
    createdBy     Int?
    isDeleted     Boolean         @default(false)
    orders        Order[]
    customerBonds CustomerBonds[]

    @@index([emailAddress, userName])
    @@map("customers_profile_data")
}

/// Stores customer's personal information and identity documents (1:1)
model CustomerPersonalInfoModel {
    id Int @id @default(autoincrement())

    SignatureUrl String?

    maritalStatus            String
    occupationType           String
    annualGrossIncome        String
    fatherOrSpouseName       String
    relationshipWithPerson   String?
    mothersName              String
    nationality              String
    maidenName               String?
    residentialStatus        String
    qualification            String
    politicallyExposedPerson String?
    dateOfBirth              String?
    signPdfUrl               String?
    confirmTimeStamp         DateTime?
    otherOccupationName      String?
    // allowTerms               Boolean                   @default(false)
    // 1-to-1 back reference
    customerProfileDataModel CustomerProfileDataModel?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("customers_personal_info")
}

/// Aadhaar card (identity proof) data model (1:1)
model AADHAARCardModel {
    id Int @id @default(autoincrement())

    firstName   String
    middleName  String?
    lastName    String
    fatherName  String?
    aadhaarNo   String
    dateOfBirth String
    gender      Gender
    image       String

    isVerified       Boolean   @default(false)
    verifyDate       DateTime?
    confirmTimeStamp DateTime?
    allowTerms       Boolean   @default(false)
    fileUrl          String

    // 1-to-1 back reference
    customerProfileDataModel CustomerProfileDataModel?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("aadhaar_cards")
}

/// PAN card (tax identity proof) data model (1:1)
model PanCardModel {
    id Int @id @default(autoincrement())

    firstName        String
    middleName       String?
    lastName         String
    panCardNo        String
    dateOfBirth      String
    gender           Gender
    image            String
    isVerified       Boolean   @default(false)
    verifyDate       DateTime?
    confirmTimeStamp DateTime?
    allowTerms       Boolean   @default(false)
    fileUrl          String?

    // 1-to-1 back reference
    customerProfileDataModel CustomerProfileDataModel?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("pan_cards")
}

/// Risk profile of a customer (1:1)
model CustomersRiskProfileModel {
    id Int @id @default(autoincrement())

    data Json[]

    // 1-to-1 back reference
    customerProfileDataModel CustomerProfileDataModel?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("customers_risk_profiles")
}

/// Address model (1:1 used for both current and permanent)
model AddressModel {
    id Int @id @default(autoincrement())

    line1          String
    line2          String?
    line3          String?
    postOffice     String
    cityOrDistrict String
    state          String
    pinCode        String
    country        String
    fullAddress    String

    // Reverse relations (1:1)
    currentAddressOf   CustomerProfileDataModel? @relation("CurrentAddress")
    permanentAddressOf CustomerProfileDataModel? @relation("PermanentAddress")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("addresses")
}

/// Bank account information linked to a customer (1-to-many)
model CustomersBankAccountModel {
    id Int @id @default(autoincrement())

    accountHolderName String
    bankAccountType   String
    accountNumber     String
    ifscCode          String
    bankName          String
    branch            String

    isPrimary        Boolean   @default(false)
    isVerified       Boolean   @default(false)
    verifyDate       DateTime?
    confirmTimeStamp DateTime?
    allowTerms       Boolean   @default(false)

    CustomerProfileDataModel   CustomerProfileDataModel? @relation(fields: [customerProfileDataModelId], references: [id])
    customerProfileDataModelId Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("customers_bank_accounts")
}

/// Demat / Broker account data (1-to-many)
model CustomersDematAccountModel {
    id Int @id @default(autoincrement())

    depositoryName            DepositoryName
    dpId                      String
    clientId                  String
    accountType               DematAccountType
    depositoryParticipantName String

    primaryPanNumber  String
    sndPanNumber      String?
    trdPanNumber      String?
    accountHolderName String

    isPrimary        Boolean   @default(false)
    isVerified       Boolean   @default(false)
    verifyDate       DateTime?
    confirmTimeStamp DateTime?
    allowTerms       Boolean   @default(false)

    CustomerProfileDataModel   CustomerProfileDataModel? @relation(fields: [customerProfileDataModelId], references: [id])
    customerProfileDataModelId Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("customers_demat_accounts")
}
