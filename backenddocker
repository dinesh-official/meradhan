FROM oven/bun:latest

WORKDIR /app

# Copy files
COPY . .

WORKDIR /app/packages/apiGateway
RUN bun install
WORKDIR /app/packages/config
RUN bun install
WORKDIR /app/packages/kyc-providers
RUN bun install
WORKDIR /app/packages/schema
RUN bun install
WORKDIR /app/backend
RUN bun install
WORKDIR /app/backend/databases/postgres
RUN bunx prisma generate
WORKDIR /app/backend
EXPOSE 4000
CMD ["bun", "start"]
